<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center"
    android:background="#1a1a2e"
    android:padding="32dp">

    <!-- Left: QR + IP -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginEnd="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LumiControl"
            android:textSize="26sp"
            android:textColor="#eee"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="正在运行"
            android:textSize="13sp"
            android:textColor="#888"
            android:layout_marginBottom="20dp" />

        <com.lumicontrol.app.widget.QrCodeView
            android:id="@+id/qrCode"
            android:layout_width="170dp"
            android:layout_height="170dp"
            android:layout_marginBottom="14dp" />

        <TextView
            android:id="@+id/tvIp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="获取中..."
            android:textSize="20sp"
            android:textColor="#e94560"
            android:textStyle="bold"
            android:layout_marginBottom="2dp" />

        <TextView
            android:id="@+id/tvQrHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="扫码连接，或浏览器手动输入上方地址"
            android:textSize="12sp"
            android:textColor="#666"
            android:gravity="center" />

    </LinearLayout>

    <!-- Right: Buttons -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginStart="24dp">

        <Button
            android:id="@+id/btnAccessibility"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="开启无障碍服务"
            android:textSize="15sp"
            android:backgroundTint="#e94560"
            style="@style/Widget.AppCompat.Button" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="点击、方向键等操作需要此权限"
            android:textSize="11sp"
            android:textColor="#555"
            android:layout_marginTop="6dp"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="（后续版本将添加设置选项）"
            android:textSize="11sp"
            android:textColor="#444"
            android:layout_marginTop="20dp"
            android:gravity="center" />

    </LinearLayout>

</LinearLayout>
