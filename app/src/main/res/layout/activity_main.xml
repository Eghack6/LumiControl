<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:background="#1a1a2e"
    android:padding="40dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_centerInParent="true">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LumiControl"
            android:textSize="28sp"
            android:textColor="#eee"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="正在运行"
            android:textSize="14sp"
            android:textColor="#888"
            android:layout_marginBottom="36dp" />

        <com.lumicontrol.app.widget.QrCodeView
            android:id="@+id/qrCode"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/tvIp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="获取中..."
            android:textSize="20sp"
            android:textColor="#e94560"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvQrHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="请在同一 WiFi 下使用手机扫码"
            android:textSize="13sp"
            android:textColor="#666"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btnAccessibility"
            android:layout_width="240dp"
            android:layout_height="44dp"
            android:text="开启无障碍服务"
            android:textSize="14sp"
            android:backgroundTint="#e94560"
            style="@style/Widget.AppCompat.Button" />

    </LinearLayout>

</RelativeLayout>
